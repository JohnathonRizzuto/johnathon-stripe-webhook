# Copy this to .env.local for local `vercel dev` testing, and set the real
# values in Vercel's project settings UI (Settings -> Environment Variables).
# Never commit .env or .env.local.

# Stripe webhook signing secret. Get it from:
#   Stripe Dashboard > Developers > Webhooks > <your endpoint> > Signing secret > Reveal
# It looks like: whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe restricted API key. Get it from:
#   Stripe Dashboard > Developers > API keys > Create restricted key
# Only needs the "Webhook endpoints" permission. Looks like: rk_live_...
STRIPE_SECRET_KEY=rk_live_replace_me

# Optional override. Defaults to ntfy.sh/johnathon-builds-2026 if not set.
NTFY_URL=https://ntfy.sh/johnathon-builds-2026

# ---------------------------------------------------------------------------
# Email sending via Gmail SMTP -- used by /api/send-email and the auto-welcome
# email fired from /api/stripe-webhook on a successful checkout.
# ---------------------------------------------------------------------------

# Gmail address that the emails will be sent FROM. This is also the inbox
# that customer replies will land in.
GMAIL_USER=johnnyrizzuto125@gmail.com

# 16-character App Password generated at:
#   https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be on for the account. The password is
# shown ONCE -- copy it immediately and paste here / into Vercel env vars.
# Looks like: xxxx xxxx xxxx xxxx  (spaces are OK, nodemailer trims them)
GMAIL_APP_PASSWORD=replace_me_with_16_char_app_password

# Shared secret that authorizes /api/send-email requests. Pick any long random
# string -- this only ever lives in env vars + each browser's localStorage.
# Anyone who has this can send email through your Gmail, so treat it like a
# password. Rotate by changing it here and re-entering in each browser.
SEND_EMAIL_KEY=replace_me_with_a_long_random_string
